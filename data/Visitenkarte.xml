   <text>
      <body>
         <pb n="1"/>
         <div type="Visitenkarte">
            <opener>
               <salute>Lieber Herr <persName ref="personen.xml#pers0007">Rößler</persName>!</salute>
               /ich komme<lb/>
            </opener>
            <p> heute abends um ½ 7h zu Ihnen. <lb/>3 Holzschnitte gaben Sie mir; <lb/>ich habe aber
               den Karton worauf <lb/>diese kleben knapp abgeschnitten, <lb/>weil ich sie rahmen
               wollte; einer <lb/>von ihnen war größer, der ist <lb/>etwas abgeschnitten. Geben Sie
                  <pb n="2"/>
               <lb/>dem Überbringer die Figur mit! </p>
               <closer>
                  <salute>Beste Grüße!</salute>
                  <signed><persName ref="personen.xml#pers0001">EGON SCHIELE</persName></signed>
               </closer>
               
         </div>
      </body>
